}

document.getElementById('m1').textContent=mean(brPBI).toFixed(2)+'%';
document.getElementById('m2').textContent=mean(frPBI).toFixed(2)+'%';
document.getElementById('m3').textContent=mean(brTop).toFixed(1)+'%';
document.getElementById('m4').textContent=mean(frTop).toFixed(1)+'%';

const G='rgba(0,0,0,0.06)';

function lineChart(id,d1,d2,c1,c2){
  new Chart(document.getElementById(id),{
    type:'line',
    data:{labels:years,datasets:[
      {label:'Brasil',data:d1,borderColor:c1,backgroundColor:'transparent',borderWidth:2,pointRadius:2,tension:0.3},
      {label:'Francia',data:d2,borderColor:c2,backgroundColor:'transparent',borderWidth:2,pointRadius:2,tension:0.3,borderDash:[6,3]}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false}},
      scales:{x:{ticks:{maxTicksLimit:12,font:{size:11}},grid:{color:G}},
              y:{ticks:{callback:v=>v.toFixed(1)+'%',font:{size:11}},grid:{color:G}}}}
  });
}

lineChart('chartPBI',brPBI,frPBI,'#009C3B','#002395');
lineChart('chartTop10',brTop,frTop,'#009C3B','#002395');

function scatterChart(id,xData,yData,color){
  const o=ols(xData,yData);
  const xMin=Math.min(...xData),xMax=Math.max(...xData);
  const pts=xData.map((x,i)=>({x:parseFloat(x.toFixed(2)),y:parseFloat(yData[i].toFixed(2))}));
  const line=[{x:parseFloat(xMin.toFixed(2)),y:parseFloat((o.a+o.b*xMin).toFixed(2))},
              {x:parseFloat(xMax.toFixed(2)),y:parseFloat((o.a+o.b*xMax).toFixed(2))}];
  new Chart(document.getElementById(id),{
    type:'scatter',
    data:{datasets:[
      {label:'Datos',data:pts,backgroundColor:color+'66',borderColor:color,borderWidth:1,pointRadius:5},
      {label:'OLS',data:line,type:'line',borderColor:color,borderWidth:2.5,pointRadius:0,borderDash:[5,4],backgroundColor:'transparent'}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`PBI: ${c.parsed.x}%  Top10: ${c.parsed.y}%`}}},
      scales:{
        x:{title:{display:true,text:'Crecimiento PBI (%)',font:{size:11}},ticks:{font:{size:11}},grid:{color:G}},
        y:{title:{display:true,text:'Top 10% ingreso (%)',font:{size:11}},ticks:{font:{size:11}},grid:{color:G}}
      }}
  });
}

scatterChart('chartScBR',brPBI,brTop,'#009C3B');
scatterChart('chartScFR',frPBI,frTop,'#002395');
</script>
